# ===========================================
# Teaching Assistant Bot - Environment Config
# ===========================================

# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here

# Database Configuration (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis Configuration (Railway provides this automatically)
REDIS_URL=redis://localhost:6379/0

# Sentry (Optional - for error tracking)
SENTRY_DSN=

# Bot Configuration
BOT_PREFIX=/
BOT_OWNER_ID=your_discord_user_id_here
BOT_LOG_LEVEL=INFO

# Environment
ENVIRONMENT=production

# UMSU Configuration
UMSU_NIM_PATTERN=^\d{10}$
UMSU_PRODI_CODES=TI,SI,SD
UMSU_MIN_ATTENDANCE=10

# Attendance Configuration
ATTENDANCE_CODE_LENGTH=6
ATTENDANCE_CODE_EXPIRY_MINUTES=15
ATTENDANCE_SESSION_TIMEOUT_MINUTES=120

# Grading Configuration
LATE_PENALTY_PER_HOUR=5
LATE_PENALTY_MAX_PERCENT=50
LATE_SUBMISSION_MAX_HOURS=24

# Gamification Configuration
EXP_BASE=100
EXP_LEVEL_MULTIPLIER=1.5
MAX_LEVEL=50

# Rate Limiting
RATE_LIMIT_COMMANDS_PER_MINUTE=10
RATE_LIMIT_COMMANDS_PER_HOUR=100
